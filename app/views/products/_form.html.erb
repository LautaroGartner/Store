<%= form_with model: product, class: "space-y-6" do |form| %>
  <% if product.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded">
      <p class="font-medium mb-1"><%= pluralize(product.errors.count, "error") %> prevented saving:</p>
      <ul class="list-disc list-inside text-sm">
        <% product.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: "block text-sm font-medium text-stone-700 mb-2" %>
    <%= form.text_field :name, class: "w-full px-4 py-2.5 bg-white border border-stone-300 rounded-lg focus:outline-none focus:border-[#D94F2B] focus:ring-1 focus:ring-[#D94F2B] transition" %>
  </div>

  <div>
    <%= form.label :inventory_count, class: "block text-sm font-medium text-stone-700 mb-2" %>
    <%= form.number_field :inventory_count, class: "w-full px-4 py-2.5 bg-white border border-stone-300 rounded-lg focus:outline-none focus:border-[#D94F2B] focus:ring-1 focus:ring-[#D94F2B] transition" %>
  </div>

  <div class="pt-2">
    <%= form.submit class: "bg-[#D94F2B] text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-[#b8401f] transition cursor-pointer" %>
  </div>
<% end %>
