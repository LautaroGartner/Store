<div class="max-w-md mx-auto">
  <h1 class="text-4xl font-semibold tracking-tight mb-8 text-center" style="font-family: 'Cormorant Garamond', serif;">
    Sign in
  </h1>

  <% if flash[:alert] %>
    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded mb-4 text-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <% if flash[:notice] %>
    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded mb-4 text-sm">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="bg-white border border-stone-200 rounded-lg p-8">
    <%= form_with url: session_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email", class: "block text-sm font-medium text-stone-700 mb-2" %>
        <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com", value: params[:email_address], class: "w-full px-4 py-2.5 bg-white border border-stone-300 rounded-lg focus:outline-none focus:border-[#D94F2B] focus:ring-1 focus:ring-[#D94F2B] transition" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "block text-sm font-medium text-stone-700 mb-2" %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "••••••••", maxlength: 72, class: "w-full px-4 py-2.5 bg-white border border-stone-300 rounded-lg focus:outline-none focus:border-[#D94F2B] focus:ring-1 focus:ring-[#D94F2B] transition" %>
      </div>

      <div class="pt-2">
        <%= form.submit "Sign in", class: "w-full bg-[#D94F2B] text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-[#b8401f] transition cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <div class="text-center mt-6">
    <%= link_to "Forgot password?", new_password_path, class: "text-sm text-stone-500 hover:text-[#D94F2B] transition" %>
  </div>
</div>
